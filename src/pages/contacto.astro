---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
---

<Layout title="Contacto | FIC 2026">
	<Hero
		title="Contacto"
		subtitle="Hablemos"
		description="¿Preguntas? ¿Sugerencias? Nos encantaría escucharte. Escribinos por cualquier canal."
	/>

	<Section id="contacto" subtitle="Formulario" title="Envianos un mensaje" description="Completá los datos y te contactamos pronto." accent="sun">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 max-w-6xl mx-auto">

			<!-- Formulario -->
			<form class="space-y-5">
				<div>
					<label class="block text-xs uppercase tracking-widest font-black mb-2 text-sun">Nombre</label>
					<input type="text" placeholder="Tu nombre" class="w-full px-5 py-3 rounded-full bg-navy-soft border-2 border-cream/20 focus:border-sun focus:outline-none transition-colors text-cream placeholder-cream/40" required />
				</div>
				<div>
					<label class="block text-xs uppercase tracking-widest font-black mb-2 text-teal">Email</label>
					<input type="email" placeholder="tu@email.com" class="w-full px-5 py-3 rounded-full bg-navy-soft border-2 border-cream/20 focus:border-teal focus:outline-none transition-colors text-cream placeholder-cream/40" required />
				</div>
				<div>
					<label class="block text-xs uppercase tracking-widest font-black mb-2 text-flame">Asunto</label>
					<select class="w-full px-5 py-3 rounded-full bg-navy-soft border-2 border-cream/20 focus:border-flame focus:outline-none transition-colors text-cream" required>
						<option value="">Seleccioná un asunto</option>
						<option>Convocatorias</option>
						<option>Espectáculos</option>
						<option>Talleres</option>
						<option>Entradas</option>
						<option>Prensa</option>
						<option>Otro</option>
					</select>
				</div>
				<div>
					<label class="block text-xs uppercase tracking-widest font-black mb-2 text-magenta">Mensaje</label>
					<textarea rows="6" placeholder="Contanos qué necesitás…" class="w-full px-5 py-4 rounded-3xl bg-navy-soft border-2 border-cream/20 focus:border-magenta focus:outline-none transition-colors text-cream placeholder-cream/40 resize-none" required></textarea>
				</div>
				<button type="submit" class="w-full bg-sun text-navy py-4 rounded-full font-black uppercase tracking-widest text-sm hover:bg-flame hover:text-cream transition-colors shadow-[6px_6px_0_0_#3DBCBC] hover:translate-x-1 hover:translate-y-1 hover:shadow-[3px_3px_0_0_#3DBCBC]">
					Enviar mensaje →
				</button>
			</form>

			<!-- Info de contacto -->
			<div class="space-y-4">
				{[
					{ titulo: "Ubicación", contenido: "Festival Internacional de Circo · Montevideo, Uruguay · 17–27 setiembre 2026", color: "#F4C430" },
					{ titulo: "Email", contenido: "info@ficuruguay.com · convocatorias@ficuruguay.com", color: "#3DBCBC" },
					{ titulo: "Teléfono", contenido: "+598 29 XXX XXX · Lun a Vie · 09:00–18:00", color: "#E85A2C" },
					{ titulo: "Redes", contenido: "@fic.uruguay en Instagram, X, Facebook y YouTube", color: "#C589B7" },
				].map(({ titulo, contenido, color }) => (
					<div class="bg-navy-soft border-2 rounded-3xl p-6 hover:-translate-y-1 transition-transform" style={`border-color:${color}`}>
						<div class="flex items-start gap-4">
							<div class="shrink-0 w-12 h-12 rounded-full overflow-hidden ring-2 ring-cream/20">
								<div class="h-1/2" style={`background:${color}`}></div>
								<div class="h-1/2 bg-navy-deep"></div>
							</div>
							<div>
								<h3 class="font-display text-xl text-cream uppercase mb-1" style={`color:${color}`}>{titulo}</h3>
								<p class="text-cream/70 text-sm leading-relaxed">{contenido}</p>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</Section>
</Layout>
