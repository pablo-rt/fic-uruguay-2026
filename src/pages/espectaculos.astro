---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
---

<Layout title="Espectáculos | FIC Uruguay 2026">
	<!-- Hero Section -->
	<Hero 
		title="Espectáculos"
		subtitle="Descubre el Circo"
		description="Más de 50 espectáculos de circo, acrobacias, teatro físico y performances innovadoras de artistas internacionales."
		backgroundImage="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&q=80"
	/>

	<!-- Categorías -->
	<Section 
		id="categorias"
		title="Categorías de Espectáculos"
		subtitle="Tipos de Actos"
		description="Explora la diversidad del circo moderno"
	>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
			<Card 
				icon="🎪"
				title="Circo Tradicional"
				description="Acrobacias clásicas, trapecio, equilibrio y técnicas ancestrales del circo."
				cta={{
					text: "Ver actos",
					href: "#"
				}}
			/>
			<Card 
				icon="🎭"
				title="Circo Contemporáneo"
				description="Fusión de circo con danza, teatro y arte moderno. Propuestas innovadoras."
				cta={{
					text: "Ver actos",
					href: "#"
				}}
			/>
			<Card 
				icon="🤸"
				title="Teatro Físico"
				description="Expresión corporal extrema, parkour, movimiento y acrobacias urbanas."
				cta={{
					text: "Ver actos",
					href: "#"
				}}
			/>
			<Card 
				icon="✨"
				title="Performance"
				description="Arte experimental, instalaciones vivas y experiencias inmersivas."
				cta={{
					text: "Ver actos",
					href: "#"
				}}
			/>
		</div>
	</Section>

	<!-- Artistas Destacados -->
	<Section 
		id="artistas"
		title="Artistas Destacados"
		subtitle="Compañías Internacionales"
		description="Conoce a algunos de los artistas que participarán en FIC 2026"
		dark={true}
	>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-[#8B3A3A]/50 transition-all">
				<div class="h-48 bg-gradient-to-br from-[#8B3A3A] to-[#6B2A2A] flex items-center justify-center text-6xl">
					🎪
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Cirque du Soleil</h3>
					<p class="text-zinc-400 text-sm mb-4">Canadá - Acrobacias aéreas y teatro físico de clase mundial.</p>
					<div class="flex gap-2 flex-wrap">
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Trapecio</span>
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Aéreo</span>
					</div>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-[#8B3A3A]/50 transition-all">
				<div class="h-48 bg-gradient-to-br from-[#8B3A3A] to-[#6B2A2A] flex items-center justify-center text-6xl">
					🤹
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Compañía Acrobática</h3>
					<p class="text-zinc-400 text-sm mb-4">Argentina - Acrobacias de piso y equilibrio extremo.</p>
					<div class="flex gap-2 flex-wrap">
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Acrobacias</span>
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Equilibrio</span>
					</div>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-[#8B3A3A]/50 transition-all">
				<div class="h-48 bg-gradient-to-br from-[#8B3A3A] to-[#6B2A2A] flex items-center justify-center text-6xl">
					🎭
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Teatro Físico Brasil</h3>
					<p class="text-zinc-400 text-sm mb-4">Brasil - Fusión de danza, circo y teatro contemporáneo.</p>
					<div class="flex gap-2 flex-wrap">
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Danza</span>
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Teatro</span>
					</div>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-[#8B3A3A]/50 transition-all">
				<div class="h-48 bg-gradient-to-br from-[#8B3A3A] to-[#6B2A2A] flex items-center justify-center text-6xl">
					🎪
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Payasos Internacionales</h3>
					<p class="text-zinc-400 text-sm mb-4">Francia - Comedia física y clown contemporáneo.</p>
					<div class="flex gap-2 flex-wrap">
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Comedia</span>
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Clown</span>
					</div>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-[#8B3A3A]/50 transition-all">
				<div class="h-48 bg-gradient-to-br from-[#8B3A3A] to-[#6B2A2A] flex items-center justify-center text-6xl">
					🤸
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Parkour Extremo</h3>
					<p class="text-zinc-400 text-sm mb-4">España - Acrobacias urbanas y movimiento extremo.</p>
					<div class="flex gap-2 flex-wrap">
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Parkour</span>
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Urbano</span>
					</div>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-[#8B3A3A]/50 transition-all">
				<div class="h-48 bg-gradient-to-br from-[#8B3A3A] to-[#6B2A2A] flex items-center justify-center text-6xl">
					✨
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Performance Experimental</h3>
					<p class="text-zinc-400 text-sm mb-4">Múltiples países - Arte contemporáneo e instalaciones vivas.</p>
					<div class="flex gap-2 flex-wrap">
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Experimental</span>
						<span class="text-xs bg-[#8B3A3A]/20 text-[#8B3A3A] px-3 py-1 rounded-full">Arte</span>
					</div>
				</div>
			</div>
		</div>
	</Section>

	<!-- Horarios -->
	<Section 
		id="horarios"
		title="Horarios de Funciones"
		subtitle="Programación"
		description="Consulta los horarios de los espectáculos"
	>
		<div class="max-w-4xl mx-auto">
			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-0">
					<div class="p-8 border-b md:border-b-0 md:border-r border-zinc-800">
						<h3 class="text-2xl font-bold text-[#8B3A3A] mb-4">Matinales</h3>
						<ul class="space-y-2 text-zinc-300">
							<li>🕐 14:00 - Espectáculos para familias</li>
							<li>🕐 16:00 - Talleres interactivos</li>
							<li>🕐 18:00 - Actos cortos</li>
						</ul>
					</div>
					<div class="p-8 border-b md:border-b-0 md:border-r border-zinc-800">
						<h3 class="text-2xl font-bold text-[#8B3A3A] mb-4">Vespertinas</h3>
						<ul class="space-y-2 text-zinc-300">
							<li>🕕 19:00 - Espectáculos principales</li>
							<li>🕖 20:30 - Actos destacados</li>
							<li>🕘 22:00 - Performances nocturnas</li>
						</ul>
					</div>
					<div class="p-8">
						<h3 class="text-2xl font-bold text-[#8B3A3A] mb-4">Especiales</h3>
						<ul class="space-y-2 text-zinc-300">
							<li>🌙 23:30 - Late night shows</li>
							<li>🎆 Fines de semana - Funciones extra</li>
							<li>🎉 Cierre - Gala de clausura</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</Section>

	<!-- CTA -->
	<Section 
		id="cta"
		title="Compra tus Entradas"
		subtitle="Asegura tu Lugar"
		dark={true}
	>
		<div class="flex flex-col sm:flex-row gap-6 justify-center">
			<a 
				href="#"
				class="px-8 py-4 bg-[#8B3A3A] text-white font-bold uppercase tracking-widest rounded-lg hover:bg-[#6B2A2A] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(139,58,58,0.5)] text-center"
			>
				Comprar Entradas
			</a>
			<a 
				href="/contacto"
				class="px-8 py-4 border-2 border-[#8B3A3A] text-[#8B3A3A] font-bold uppercase tracking-widest rounded-lg hover:bg-[#8B3A3A] hover:text-white transition-all duration-300 text-center"
			>
				Más Información
			</a>
		</div>
	</Section>
</Layout>
