---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';

const categorias = [
	{ icon: "✦", titulo: "Circo Tradicional", desc: "Acrobacias clásicas, trapecio, equilibrio y técnicas ancestrales del circo.", accent: "sun" as const },
	{ icon: "◐", titulo: "Circo Contemporáneo", desc: "Fusión de circo con danza, teatro y arte moderno. Propuestas innovadoras.", accent: "teal" as const },
	{ icon: "✺", titulo: "Teatro Físico", desc: "Expresión corporal extrema, parkour, movimiento y acrobacias urbanas.", accent: "flame" as const },
	{ icon: "❍", titulo: "Performance", desc: "Arte experimental, instalaciones vivas y experiencias inmersivas.", accent: "magenta" as const },
];

const artistas = [
	{ nombre: "Cirque du Soleil", origen: "Canadá", desc: "Acrobacias aéreas y teatro físico de clase mundial.", tags: ["Trapecio", "Aéreo"], color: "#F4C430" },
	{ nombre: "Compañía Acrobática", origen: "Argentina", desc: "Acrobacias de piso y equilibrio extremo.", tags: ["Acrobacias", "Equilibrio"], color: "#3DBCBC" },
	{ nombre: "Teatro Físico Brasil", origen: "Brasil", desc: "Fusión de danza, circo y teatro contemporáneo.", tags: ["Danza", "Teatro"], color: "#E85A2C" },
	{ nombre: "Payasos Internacionales", origen: "Francia", desc: "Comedia física y clown contemporáneo.", tags: ["Comedia", "Clown"], color: "#C589B7" },
	{ nombre: "Parkour Extremo", origen: "España", desc: "Acrobacias urbanas y movimiento extremo.", tags: ["Parkour", "Urbano"], color: "#8E5BA8" },
	{ nombre: "Performance Experimental", origen: "Multinacional", desc: "Arte contemporáneo e instalaciones vivas.", tags: ["Experimental", "Arte"], color: "#B83A3A" },
];
---

<Layout title="Espectáculos | FIC 2026">
	<Hero
		title="Espectáculos"
		subtitle="Descubrí el Circo"
		description="Más de 50 espectáculos de circo, acrobacias, teatro físico y performances innovadoras de artistas internacionales."
		cta={{ text: "Ver programación", href: "/programacion" }}
	/>

	<Section id="categorias" subtitle="Tipos de Acto" title="Categorías" description="Explorá la diversidad del circo moderno." accent="teal">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
			{categorias.map(c => (
				<Card icon={c.icon} accent={c.accent} title={c.titulo} description={c.desc} cta={{ text: "Ver actos", href: "#" }} />
			))}
		</div>
	</Section>

	<Section id="artistas" subtitle="Compañías Internacionales" title="Artistas Destacados" description="Algunos de los nombres que vas a ver en FIC 2026." dark={true} accent="magenta">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
			{artistas.map(a => (
				<div class="group bg-navy-soft border-2 rounded-3xl overflow-hidden hover:-translate-y-1 transition-all" style={`border-color:${a.color}`}>
					<div class="relative h-44 flex items-center justify-center" style={`background:${a.color}`}>
						<div class="absolute inset-0 flex flex-col">
							<div class="flex-1" style={`background:${a.color}`}></div>
							<div class="flex-1 bg-navy-deep"></div>
						</div>
						<div class="relative w-32 h-32 rounded-full overflow-hidden ring-4 ring-cream">
							<div class="h-1/2 bg-cream"></div>
							<div class="h-1/2" style={`background:${a.color}`}></div>
						</div>
					</div>
					<div class="p-6">
						<p class="text-xs uppercase tracking-widest mb-1 font-black" style={`color:${a.color}`}>{a.origen}</p>
						<h3 class="font-display text-2xl text-cream mb-2 uppercase tracking-tight leading-tight">{a.nombre}</h3>
						<p class="text-cream/70 text-sm mb-4">{a.desc}</p>
						<div class="flex gap-2 flex-wrap">
							{a.tags.map(t => (
								<span class="text-xs font-bold px-3 py-1 rounded-full text-navy" style={`background:${a.color}`}>{t}</span>
							))}
						</div>
					</div>
				</div>
			))}
		</div>
	</Section>

	<section class="bg-flame text-navy py-20 md:py-28 border-y-4 border-navy">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="font-display text-5xl md:text-7xl uppercase tracking-tighter mb-8 leading-[0.85]">
				Asegurá tu lugar
			</h2>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/programacion" class="bg-navy text-cream px-8 py-4 rounded-full font-black uppercase tracking-widest text-sm hover:bg-cream hover:text-navy transition-colors shadow-[6px_6px_0_0_#0E1B3D] hover:translate-x-1 hover:translate-y-1 hover:shadow-[3px_3px_0_0_#0E1B3D]">
					Ver programación →
				</a>
				<a href="/contacto" class="border-4 border-navy px-8 py-4 rounded-full font-black uppercase tracking-widest text-sm hover:bg-navy hover:text-cream transition-colors">
					Contacto
				</a>
			</div>
		</div>
	</section>
</Layout>
