---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import erratico from '../assets/artistas/El errático comportamiento de los seres.jpg';
import rumba from '../assets/artistas/Rumba.jpg';
import nasdrovia from '../assets/artistas/nasdrovia .jpg';

const espectaculos = [
  {
    titulo: "Red Sin Vuelo",
    compania: "Cía. Vértice",
    lugar: "Teatro Solis",
    fechas: [17, 19, 22],
    imagen: erratico.src,
  },
  {
    titulo: "Gravedad Intensa",
    compania: "Colectivo Aéreo",
    lugar: "Sala Lazaroff",
    fechas: [17, 21, 25],
    imagen: rumba.src,
  },
  {
    titulo: "Tifon",
    compania: "Duo Akimbo",
    lugar: "Plaza las Pioneras",
    fechas: [18, 20],
    imagen: nasdrovia.src,
  },
  {
    titulo: "Alcachofas Fritas",
    compania: "Trupe Ignición",
    lugar: "Plaza Liber Seregni",
    fechas: [19, 21, 23],
    imagen: "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "El Gran Desfile",
    compania: "FIC Compañía Estable",
    lugar: "Centro Cultural Goes",
    fechas: [20, 27],
    imagen: "https://images.unsplash.com/photo-1525026198548-4baa812f1183?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "Repasadores Mojados",
    compania: "Colectivo Eje",
    lugar: "Centro Cultural España",
    fechas: [22, 24, 26],
    imagen: "https://images.unsplash.com/photo-1547036967-23d11aacaee0?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "Malabares del Fin del Mundo",
    compania: "Los Tres Puntos",
    lugar: "Club Cultural Artesano",
    fechas: [23, 25],
    imagen: "https://images.unsplash.com/photo-1568702846914-96b305d2aaeb?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "LaLaDera",
    compania: "Petit Ensemble",
    lugar: "Sala Lazaroff",
    fechas: [24, 26, 27],
    imagen: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "Alta Tensión",
    compania: "Cuerda Floja Colectivo",
    lugar: "Teatro Solis",
    fechas: [25, 26, 27],
    imagen: "https://images.unsplash.com/photo-1530685932526-48ec92998eaa?auto=format&fit=crop&q=80&w=800",
  },
];

const daysWithShows = new Set(espectaculos.flatMap(e => e.fechas));

const lugares = [...new Set(espectaculos.map(e => e.lugar))].sort();

// Calendario septiembre 2026
// 1 sep 2026 = martes → en grilla Lu-Do: offset de 1 celda vacía
const CALENDAR_OFFSET = 1;
const DAYS_IN_MONTH = 30;
const calendarCells: (number | null)[] = [];
for (let i = 0; i < CALENDAR_OFFSET; i++) calendarCells.push(null);
for (let d = 1; d <= DAYS_IN_MONTH; d++) calendarCells.push(d);
while (calendarCells.length % 7 !== 0) calendarCells.push(null);
---

<Layout title="Programación | FIC Uruguay 2026">
  <Hero
    title="Programación"
    subtitle="FIC Uruguay 2026"
    description="Explorá la agenda completa del festival. Espectáculos, compañías y fechas para que no te pierdas nada."
    backgroundImage="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?auto=format&fit=crop&q=80"
  />

  <Section
    id="espectaculos"
    subtitle="Agenda Completa"
    title="Espectáculos"
    description="17 al 27 de setiembre de 2026 · Montevideo, Uruguay"
  >

    <!-- ── FILTROS ───────────────────────────────────────────── -->
    <div class="mb-12 flex flex-col lg:flex-row gap-4 items-start">

      <!-- Calendario (colapsable) -->
      <div class="w-full lg:w-80">
        <button
          id="toggle-fecha"
          class="w-full flex justify-between items-center px-5 py-3 bg-navy-soft border-2 border-sun/30 rounded-full text-left hover:border-sun transition-all duration-200 group"
          aria-expanded="false"
        >
          <span class="text-xs uppercase tracking-widest text-sun font-black">◐ Filtrar por fecha</span>
          <svg id="arrow-fecha" class="w-4 h-4 text-cream transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="panel-fecha" class="hidden mt-2 bg-navy-soft border-2 border-sun/30 rounded-3xl p-5">
          <p class="text-center text-sm font-black uppercase tracking-widest text-cream mb-4">Setiembre 2026</p>
          <div class="grid grid-cols-7 mb-1">
            {['Lu','Ma','Mi','Ju','Vi','Sa','Do'].map(d => (
              <div class="text-center text-cream/40 text-xs font-bold py-1">{d}</div>
            ))}
          </div>
          <div class="grid grid-cols-7 gap-y-1">
            {calendarCells.map(day => (
              day === null
                ? <div />
                : daysWithShows.has(day)
                  ? (
                    <button
                      data-day={day}
                      class="calendar-day w-9 h-9 mx-auto rounded-full text-sm font-bold text-cream hover:bg-flame hover:text-cream transition-all duration-200 cursor-pointer"
                    >
                      {day}
                    </button>
                  )
                  : (
                    <div class="w-9 h-9 mx-auto rounded-full text-sm text-cream/20 flex items-center justify-center cursor-not-allowed select-none">
                      {day}
                    </div>
                  )
            ))}
          </div>
        </div>
      </div>

      <!-- Lugar (colapsable) -->
      <div class="flex-1 w-full">
        <button
          id="toggle-lugar"
          class="w-full flex justify-between items-center px-5 py-3 bg-navy-soft border-2 border-teal/30 rounded-full text-left hover:border-teal transition-all duration-200"
          aria-expanded="false"
        >
          <span class="text-xs uppercase tracking-widest text-teal font-black">◐ Filtrar por lugar</span>
          <svg id="arrow-lugar" class="w-4 h-4 text-cream transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="panel-lugar" class="hidden mt-2 bg-navy-soft border-2 border-teal/30 rounded-3xl p-5">
          <div class="flex flex-wrap gap-2">
            {lugares.map(lugar => (
              <button
                data-lugar-filter={lugar}
                class="lugar-btn px-4 py-2 rounded-full text-sm font-semibold border-2 border-cream/30 text-cream/80 hover:border-teal hover:text-teal transition-all duration-200 cursor-pointer"
              >
                {lugar}
              </button>
            ))}
          </div>
        </div>
      </div>

    </div>

    <!-- Estado de filtros activos + limpiar -->
    <div id="filter-status" class="mb-8 hidden items-center gap-4">
      <p class="text-cream/70 text-sm">
        Mostrando <span id="result-count" class="text-sun font-black text-base">{espectaculos.length}</span> espectáculo(s)
      </p>
      <button
        id="clear-filters"
        class="text-xs uppercase tracking-widest font-black text-flame hover:text-sun transition-colors duration-200 underline underline-offset-4 decoration-2"
      >
        ✕ Limpiar filtros
      </button>
    </div>
    <!-- ── FIN FILTROS ────────────────────────────────────────── -->

    <!-- Grilla de tarjetas -->
    <div id="cards-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {espectaculos.map((show, i) => {
        const colors = ['#F4C430','#3DBCBC','#E85A2C','#C589B7','#8E5BA8','#B83A3A'];
        const aHex = colors[i % colors.length];
        return (
        <article
          data-card
          data-fechas={show.fechas.join(',')}
          data-lugar={show.lugar}
          class="relative group rounded-3xl overflow-hidden border-2 transition-all duration-300 bg-navy-soft hover:-translate-y-1"
          style={`border-color:${aHex}`}
        >
          <!-- Cintita bicolor superior -->
          <div class="h-2 flex">
            <div class="flex-1" style={`background:${aHex}`}></div>
            <div class="flex-1 bg-teal"></div>
            <div class="flex-1 bg-flame"></div>
            <div class="flex-1 bg-magenta"></div>
          </div>

          <!-- Imagen -->
          <div class="relative h-52 overflow-hidden">
            <img
              src={show.imagen}
              alt={show.titulo}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <!-- Círculo bicolor decorativo -->
            <div class="absolute top-3 right-3 w-12 h-12 rounded-full overflow-hidden ring-2 ring-cream">
              <div class="h-1/2" style={`background:${aHex}`}></div>
              <div class="h-1/2 bg-teal"></div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-navy-deep via-navy-deep/80 to-transparent px-4 py-4">
              <div class="flex flex-wrap gap-1.5">
                {show.fechas.map((dia) => (
                  <span class="bg-cream text-navy text-xs font-black px-2.5 py-1 rounded-full uppercase tracking-wider">
                    {dia} set
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Contenido -->
          <div class="p-6">
            <h3 class="font-display text-2xl text-cream uppercase tracking-tight leading-[0.95] mb-2 group-hover:translate-x-1 transition-transform" style={`color:${aHex}`}>
              {show.titulo}
            </h3>
            <p class="text-cream font-bold text-sm mb-1">{show.compania}</p>
            <p class="text-cream/60 text-sm mb-6">📍 {show.lugar}</p>

            <div class="flex gap-2">
              <a
                href="#"
                class="flex-1 text-center text-xs font-black uppercase tracking-widest py-2.5 rounded-full border-2 border-cream/30 text-cream/80 hover:border-cream hover:text-cream transition-all duration-300"
              >
                Detalles
              </a>
              <a
                href="#"
                class="flex-1 text-center text-xs font-black uppercase tracking-widest py-2.5 rounded-full text-navy hover:bg-cream transition-all duration-300"
                style={`background:${aHex}`}
              >
                Entradas
              </a>
            </div>
          </div>
        </article>
        );
      })}
    </div>

    <!-- Sin resultados -->
    <div id="no-results" class="hidden text-center py-20">
      <div class="inline-block w-20 h-20 rounded-full overflow-hidden mb-4">
        <div class="h-1/2 bg-flame"></div>
        <div class="h-1/2 bg-magenta"></div>
      </div>
      <p class="text-cream/70 text-lg mb-2 font-display uppercase">No hay espectáculos</p>
      <p class="text-cream/50 text-sm mb-4">Probá con otros filtros</p>
      <button
        id="clear-filters-2"
        class="text-sm font-black text-sun underline underline-offset-4 decoration-2 hover:text-flame transition-colors"
      >
        Ver todos los espectáculos
      </button>
    </div>

  </Section>
</Layout>

<script>
  // ── Acordeones de filtros ───────────────────────────────────
  function setupToggle(btnId: string, panelId: string, arrowId: string) {
    const btn = document.getElementById(btnId)!;
    const panel = document.getElementById(panelId)!;
    const arrow = document.getElementById(arrowId)!;
    btn.addEventListener('click', () => {
      const open = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden', open);
      arrow.style.transform = open ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', String(!open));
    });
  }

  setupToggle('toggle-fecha', 'panel-fecha', 'arrow-fecha');
  setupToggle('toggle-lugar', 'panel-lugar', 'arrow-lugar');

  // ── Estado ─────────────────────────────────────────────────
  const cards = document.querySelectorAll<HTMLElement>('[data-card]');
  const resultCount = document.getElementById('result-count')!;
  const filterStatus = document.getElementById('filter-status')!;
  const noResults = document.getElementById('no-results')!;
  const cardsGrid = document.getElementById('cards-grid')!;

  const selectedDays = new Set<number>();
  let selectedLugar: string | null = null;

  // ── Calendario: visuals ─────────────────────────────────────
  function updateCalendarVisuals() {
    const dayBtns = document.querySelectorAll<HTMLElement>('.calendar-day');

    const min = selectedDays.size > 0 ? Math.min(...selectedDays) : null;
    const max = selectedDays.size > 0 ? Math.max(...selectedDays) : null;

    dayBtns.forEach(btn => {
      const d = Number(btn.dataset.day);
      const isEndpoint = min !== null && (d === min || d === max);
      const isMiddle = min !== null && max !== null && d > min && d < max;

      btn.classList.remove(
        'bg-flame', 'ring-2', 'ring-sun', 'text-cream',
        'bg-flame/40', 'text-cream/80'
      );

      if (isEndpoint) {
        btn.classList.add('bg-flame', 'ring-2', 'ring-sun', 'text-cream');
      } else if (isMiddle) {
        btn.classList.add('bg-flame/40', 'text-cream/80');
      }
    });
  }

  // ── Filtrado ────────────────────────────────────────────────
  function applyFilters() {
    const min = selectedDays.size > 0 ? Math.min(...selectedDays) : null;
    const max = selectedDays.size > 0 ? Math.max(...selectedDays) : null;

    let visible = 0;
    cards.forEach(card => {
      const fechas = card.dataset.fechas!.split(',').map(Number);
      const lugar = card.dataset.lugar!;

      const matchDay = min === null || fechas.some(f => f >= min && f <= max!);
      const matchLugar = !selectedLugar || lugar === selectedLugar;

      const show = matchDay && matchLugar;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    resultCount.textContent = String(visible);

    const hasFilter = selectedDays.size > 0 || selectedLugar !== null;
    filterStatus.classList.toggle('hidden', !hasFilter);
    filterStatus.classList.toggle('flex', hasFilter);
    noResults.classList.toggle('hidden', visible > 0);
    cardsGrid.classList.toggle('hidden', visible === 0);
  }

  function clearFilters() {
    selectedDays.clear();
    selectedLugar = null;
    updateCalendarVisuals();
    document.querySelectorAll<HTMLElement>('.lugar-btn').forEach(btn => {
      btn.classList.remove('bg-teal', 'border-teal', 'text-navy');
      btn.classList.add('border-cream/30', 'text-cream/80');
    });
    applyFilters();
  }

  // ── Listeners: calendario ───────────────────────────────────
  document.querySelectorAll<HTMLElement>('.calendar-day').forEach(btn => {
    btn.addEventListener('click', () => {
      const day = Number(btn.dataset.day);

      if (selectedDays.has(day)) {
        // Toggle: deseleccionar esta fecha
        selectedDays.delete(day);
      } else {
        // Si el día clickeado está dentro del rango actual, recortar el rango
        const currentMax = selectedDays.size > 0 ? Math.max(...selectedDays) : null;
        if (currentMax !== null && day < currentMax) {
          for (const d of [...selectedDays]) {
            if (d > day) selectedDays.delete(d);
          }
        }
        selectedDays.add(day);
      }

      updateCalendarVisuals();
      applyFilters();
    });
  });

  // ── Listeners: lugar ────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.lugar-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lugar = btn.dataset.lugarFilter!;
      if (selectedLugar === lugar) {
        selectedLugar = null;
        btn.classList.remove('bg-teal', 'border-teal', 'text-navy');
        btn.classList.add('border-cream/30', 'text-cream/80');
      } else {
        selectedLugar = lugar;
        document.querySelectorAll<HTMLElement>('.lugar-btn').forEach(b => {
          b.classList.remove('bg-teal', 'border-teal', 'text-navy');
          b.classList.add('border-cream/30', 'text-cream/80');
        });
        btn.classList.remove('border-cream/30', 'text-cream/80');
        btn.classList.add('bg-teal', 'border-teal', 'text-navy');
      }
      applyFilters();
    });
  });

  document.getElementById('clear-filters')?.addEventListener('click', clearFilters);
  document.getElementById('clear-filters-2')?.addEventListener('click', clearFilters);
</script>
