---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
---

<Layout title="Talleres | FIC Uruguay 2026">
	<!-- Hero Section -->
	<Hero 
		title="Talleres"
		subtitle="Aprende del Circo"
		description="Talleres intensivos con maestros circenses internacionales. Para todos los niveles, desde principiantes hasta profesionales."
		backgroundImage="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80"
	/>

	<!-- Talleres Disponibles -->
	<Section 
		id="talleres"
		title="Talleres Disponibles"
		subtitle="Formación Circense"
		description="Elige entre nuestros talleres especializados"
	>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<Card 
				icon="🎪"
				title="Trapecio Aéreo"
				description="Aprende las técnicas fundamentales del trapecio con instructores de clase mundial. Incluye seguridad y progresión."
				cta={{
					text: "Inscribirse",
					href: "#"
				}}
			/>
			<Card 
				icon="🤸"
				title="Acrobacias de Piso"
				description="Domina las acrobacias básicas y avanzadas. Trabajo en equipo, equilibrio y confianza."
				cta={{
					text: "Inscribirse",
					href: "#"
				}}
			/>
			<Card 
				icon="🎭"
				title="Clown y Comedia"
				description="Técnicas de clown, improvisación y comedia física. Desarrolla tu personaje único."
				cta={{
					text: "Inscribirse",
					href: "#"
				}}
			/>
			<Card 
				icon="🤹"
				title="Malabares"
				description="Desde lo básico hasta patrones complejos. Técnicas tradicionales y modernas."
				cta={{
					text: "Inscribirse",
					href: "#"
				}}
			/>
			<Card 
				icon="🎪"
				title="Equilibrio y Contorsión"
				description="Flexibilidad extrema, equilibrio en objetos y técnicas de contorsión segura."
				cta={{
					text: "Inscribirse",
					href: "#"
				}}
			/>
			<Card 
				icon="✨"
				title="Teatro Físico"
				description="Expresión corporal, movimiento contemporáneo y fusión con circo moderno."
				cta={{
					text: "Inscribirse",
					href: "#"
				}}
			/>
		</div>
	</Section>

	<!-- Instructores -->
	<Section 
		id="instructores"
		title="Nuestros Instructores"
		subtitle="Maestros Internacionales"
		description="Aprende de los mejores artistas circenses del mundo"
		dark={true}
	>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="h-40 bg-gradient-to-br from-[#E63946] to-[#d62828] flex items-center justify-center text-5xl">
					🎪
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-1">Marco Rossi</h3>
					<p class="text-[#E63946] text-sm font-semibold mb-3">Trapecista - Italia</p>
					<p class="text-zinc-400 text-sm">20 años de experiencia en acrobacias aéreas. Ha trabajado con Cirque du Soleil.</p>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="h-40 bg-gradient-to-br from-[#E63946] to-[#d62828] flex items-center justify-center text-5xl">
					🤹
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-1">Ana Silva</h3>
					<p class="text-[#E63946] text-sm font-semibold mb-3">Acróbata - Brasil</p>
					<p class="text-zinc-400 text-sm">Especialista en acrobacias de piso y trabajo en equipo. Campeona mundial.</p>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="h-40 bg-gradient-to-br from-[#E63946] to-[#d62828] flex items-center justify-center text-5xl">
					🎭
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-1">Pierre Dubois</h3>
					<p class="text-[#E63946] text-sm font-semibold mb-3">Clown - Francia</p>
					<p class="text-zinc-400 text-sm">Maestro del clown contemporáneo. Ganador de múltiples premios internacionales.</p>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="h-40 bg-gradient-to-br from-[#E63946] to-[#d62828] flex items-center justify-center text-5xl">
					🤸
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-1">Carlos Mendez</h3>
					<p class="text-[#E63946] text-sm font-semibold mb-3">Malabarista - España</p>
					<p class="text-zinc-400 text-sm">Experto en malabares tradicionales y contemporáneos. Profesor certificado.</p>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="h-40 bg-gradient-to-br from-[#E63946] to-[#d62828] flex items-center justify-center text-5xl">
					🎪
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-1">Yuki Tanaka</h3>
					<p class="text-[#E63946] text-sm font-semibold mb-3">Equilibrista - Japón</p>
					<p class="text-zinc-400 text-sm">Especialista en equilibrio extremo y contorsión. Artista de circo de élite.</p>
				</div>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl overflow-hidden">
				<div class="h-40 bg-gradient-to-br from-[#E63946] to-[#d62828] flex items-center justify-center text-5xl">
					✨
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-1">Sofia Moreno</h3>
					<p class="text-[#E63946] text-sm font-semibold mb-3">Teatro Físico - Argentina</p>
					<p class="text-zinc-400 text-sm">Directora de compañía de teatro físico. Innovadora en circo contemporáneo.</p>
				</div>
			</div>
		</div>
	</Section>

	<!-- Información Práctica -->
	<Section 
		id="info"
		title="Información Práctica"
		subtitle="Detalles de los Talleres"
		description="Todo lo que necesitas saber para participar"
	>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<h3 class="text-2xl font-bold mb-4 text-[#E63946]">📅 Horarios</h3>
				<ul class="space-y-3 text-zinc-300">
					<li><strong>Mañana:</strong> 09:00 - 12:00</li>
					<li><strong>Tarde:</strong> 14:00 - 17:00</li>
					<li><strong>Noche:</strong> 18:00 - 21:00</li>
					<li><strong>Duración:</strong> 3 horas por sesión</li>
				</ul>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<h3 class="text-2xl font-bold mb-4 text-[#E63946]">💰 Precios</h3>
				<ul class="space-y-3 text-zinc-300">
					<li><strong>Taller único:</strong> $50 USD</li>
					<li><strong>3 talleres:</strong> $120 USD</li>
					<li><strong>Pase completo:</strong> $200 USD</li>
					<li><strong>Estudiantes:</strong> 20% descuento</li>
				</ul>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<h3 class="text-2xl font-bold mb-4 text-[#E63946]">👥 Niveles</h3>
				<ul class="space-y-3 text-zinc-300">
					<li>✓ Principiante - Sin experiencia</li>
					<li>✓ Intermedio - Experiencia básica</li>
					<li>✓ Avanzado - Profesionales</li>
					<li>✓ Todos los niveles bienvenidos</li>
				</ul>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<h3 class="text-2xl font-bold mb-4 text-[#E63946]">📋 Requisitos</h3>
				<ul class="space-y-3 text-zinc-300">
					<li>✓ Ropa cómoda y deportiva</li>
					<li>✓ Zapatos deportivos</li>
					<li>✓ Botella de agua</li>
					<li>✓ Seguro de accidentes (incluido)</li>
				</ul>
			</div>
		</div>
	</Section>

	<!-- Testimonios -->
	<Section 
		id="testimonios"
		title="Lo que Dicen los Participantes"
		subtitle="Experiencias"
		description="Historias de artistas que aprendieron en nuestros talleres"
		dark={true}
	>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full bg-[#E63946] flex items-center justify-center font-bold">
						LM
					</div>
					<div>
						<h4 class="font-bold">Lucas Martínez</h4>
						<p class="text-sm text-zinc-400">Acróbata, Uruguay</p>
					</div>
				</div>
				<p class="text-zinc-300 italic">"Los talleres de FIC cambiaron mi carrera. Aprendí técnicas que no encontraba en ningún otro lugar."</p>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full bg-[#E63946] flex items-center justify-center font-bold">
						JG
					</div>
					<div>
						<h4 class="font-bold">Juana García</h4>
						<p class="text-sm text-zinc-400">Trapecista, Paraguay</p>
					</div>
				</div>
				<p class="text-zinc-300 italic">"La experiencia de aprender de maestros internacionales fue invaluable. Recomiendo FIC a todos."</p>
			</div>

			<div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full bg-[#E63946] flex items-center justify-center font-bold">
						RP
					</div>
					<div>
						<h4 class="font-bold">Roberto Pérez</h4>
						<p class="text-sm text-zinc-400">Clown, Chile</p>
					</div>
				</div>
				<p class="text-zinc-300 italic">"Conocí artistas de todo el mundo y formé conexiones que duraron años. Increíble experiencia."</p>
			</div>
		</div>
	</Section>

	<!-- CTA -->
	<Section 
		id="cta"
		title="¿Listo para Aprender?"
		subtitle="Inscríbete Ahora"
		dark={true}
	>
		<div class="flex flex-col sm:flex-row gap-6 justify-center">
			<a 
				href="#"
				class="px-8 py-4 bg-[#E63946] text-white font-bold uppercase tracking-widest rounded-lg hover:bg-[#d62828] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(230,57,70,0.5)] text-center"
			>
				Inscribirse en Talleres
			</a>
			<a 
				href="/contacto"
				class="px-8 py-4 border-2 border-[#E63946] text-[#E63946] font-bold uppercase tracking-widest rounded-lg hover:bg-[#E63946] hover:text-white transition-all duration-300 text-center"
			>
				Más Información
			</a>
		</div>
	</Section>
</Layout>
