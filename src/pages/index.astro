---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
---

<Layout title="FIC Uruguay 2026 | Festival Internacional de Circo">
	<!-- Hero Section -->
	<Hero 
		title="FIC 2026"
		subtitle="Festival Internacional de Circo"
		description="La 5ta edición del mayor festival de circo de América Latina. Celebrando el arte, la acrobacia y la magia del circo en Montevideo."
		cta={{
			text: "Descubre más",
			href: "#sobre"
		}}
	/>

	<!-- Sobre el Festival -->
	<Section 
		id="sobre"
		title="Sobre el Festival"
		subtitle="Conoce FIC"
		description="Un espacio dedicado a celebrar el arte circense en todas sus formas"
	>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<Card 
				icon="🎪"
				title="Tradición"
				description="Desde 2002, FIC ha sido la plataforma principal para artistas circenses de toda América Latina."
				cta={{
					text: "Historia",
					href: "#"
				}}
			/>
			<Card 
				icon="🌍"
				title="Alcance Internacional"
				description="Artistas de más de 30 países participan en nuestro festival cada año."
				cta={{
					text: "Artistas",
					href: "/espectaculos"
				}}
			/>
			<Card 
				icon="✨"
				title="Innovación"
				description="Combinamos técnicas tradicionales con propuestas contemporáneas y experimentales."
				cta={{
					text: "Espectáculos",
					href: "/espectaculos"
				}}
			/>
		</div>
	</Section>

	<!-- Ediciones Anteriores -->
	<Section 
		id="ediciones"
		title="Ediciones Anteriores"
		subtitle="Nuestro Legado"
		description="Más de dos décadas celebrando el arte circense"
		dark={true}
	>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
			<Card 
				title="2022"
				description="4ta Edición - 15,000 asistentes"
				featured={false}
			/>
			<Card 
				title="2019"
				description="3ra Edición - 12,000 asistentes"
				featured={false}
			/>
			<Card 
				title="2016"
				description="2da Edición - 10,000 asistentes"
				featured={false}
			/>
			<Card 
				title="2002"
				description="1ra Edición - Inicio de la tradición"
				featured={false}
			/>
		</div>
	</Section>

	<!-- Próximos Eventos -->
	<Section 
		id="eventos"
		title="Próximos Eventos"
		subtitle="Qué Esperar"
		description="Descubre lo que te espera en FIC 2026"
	>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<Card 
				featured={true}
				title="Convocatorias"
				description="Abierto el llamado para compañías y artistas independientes. Participa en la 5ta edición del festival más importante de circo en América Latina."
				cta={{
					text: "Postúlate ahora",
					href: "/convocatorias"
				}}
			/>
			<Card 
				icon="🎭"
				title="Espectáculos"
				description="Más de 50 espectáculos de circo, acrobacias, teatro físico y performances innovadoras."
				cta={{
					text: "Ver programa",
					href: "/espectaculos"
				}}
			/>
			<Card 
				icon="🎓"
				title="Talleres"
				description="Aprende de maestros circenses internacionales. Talleres para todos los niveles."
				cta={{
					text: "Inscribirse",
					href: "/talleres"
				}}
			/>
		</div>
	</Section>

	<!-- Testimonios -->
	<Section 
		id="testimonios"
		title="Lo que Dicen los Artistas"
		subtitle="Testimonios"
		description="Voces de la comunidad circense"
		dark={false}
	>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<div class="bg-white/10 border border-[#D4A574]/30 p-8 rounded-2xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full bg-[#8B3A3A] flex items-center justify-center font-bold text-white">
						MC
					</div>
					<div>
						<h4 class="font-bold">María Cortés</h4>
						<p class="text-sm text-zinc-300">Acróbata, Argentina</p>
					</div>
				</div>
				<p class="text-zinc-200 italic">"FIC es el lugar donde el circo latinoamericano brilla. Una experiencia única que no me puedo perder cada año."</p>
			</div>

			<div class="bg-white/10 border border-[#D4A574]/30 p-8 rounded-2xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full bg-[#8B3A3A] flex items-center justify-center font-bold text-white">
						JL
					</div>
					<div>
						<h4 class="font-bold">Juan López</h4>
						<p class="text-sm text-zinc-300">Payaso, Uruguay</p>
					</div>
				</div>
				<p class="text-zinc-200 italic">"El festival nos da la oportunidad de mostrar nuestro trabajo a una audiencia apasionada y conectar con otros artistas."</p>
			</div>

			<div class="bg-white/10 border border-[#D4A574]/30 p-8 rounded-2xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full bg-[#8B3A3A] flex items-center justify center font-bold text-white">
						SP
					</div>
					<div>
						<h4 class="font-bold">Sofia Pérez</h4>
						<p class="text-sm text-zinc-300">Trapecista, Brasil</p>
					</div>
				</div>
				<p class="text-zinc-200 italic">"Montevideo se transforma durante FIC. La energía, la pasión y el apoyo del público es incomparable."</p>
			</div>
		</div>
	</Section>

	<!-- Newsletter -->
	<Section 
		id="newsletter"
		title="Mantente Actualizado"
		subtitle="Newsletter"
		description="Recibe las últimas noticias sobre FIC 2026"
	>
		<div class="max-w-2xl mx-auto">
			<form class="flex flex-col sm:flex-row gap-4">
				<input 
					type="email" 
					placeholder="Tu correo electrónico"
					class="flex-1 px-6 py-3 rounded-lg bg-white/20 border border-[#D4A574]/50 focus:border-[#8B3A3A] focus:outline-none transition-colors text-white placeholder-zinc-300"
					required
				/>
				<button 
					type="submit"
					class="px-8 py-3 bg-[#8B3A3A] text-white font-bold uppercase tracking-widest rounded-lg hover:bg-[#D4A574] hover:text-[#4A7C8C] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(139,58,58,0.5)]"
				>
					Suscribirse
				</button>
			</form>
			<p class="text-center text-zinc-300 text-sm mt-4">
				No compartimos tu email. Puedes desuscribirte en cualquier momento.
			</p>
		</div>
	</Section>

	<!-- CTA Final -->
	<Section 
		id="cta"
		title="¿Listo para el Circo?"
		subtitle="Únete a Nosotros"
		dark={false}
	>
		<div class="flex flex-col sm:flex-row gap-6 justify-center">
			<a 
				href="/convocatorias"
				class="px-8 py-4 bg-[#8B3A3A] text-white font-bold uppercase tracking-widest rounded-lg hover:bg-[#D4A574] hover:text-[#4A7C8C] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(139,58,58,0.5)] text-center"
			>
				Participa como Artista
			</a>
			<a 
				href="/contacto"
				class="px-8 py-4 border-2 border-[#8B3A3A] text-[#8B3A3A] font-bold uppercase tracking-widest rounded-lg hover:bg-[#8B3A3A] hover:text-white transition-all duration-300 text-center"
			>
				Contacta con Nosotros
			</a>
		</div>
	</Section>
</Layout>
