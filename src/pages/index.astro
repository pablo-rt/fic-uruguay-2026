---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import HalfCircleStrip from '../components/HalfCircleStrip.astro';
---

<Layout title="FIC 2026 · Festival Internacional de Circo">

	<Hero
		title="FIC 2026"
		subtitle="Festival Internacional de Circo · Uruguay"
		description="La 5ta edición del mayor festival de circo de América Latina. Diez días de espectáculos, talleres y arte vivo en Montevideo."
		cta={{ text: "Ver programación", href: "/programacion" }}
	/>

	<!-- Marquee de palabras -->
	<div class="bg-sun text-navy py-5 overflow-hidden border-b-4 border-navy">
		<div class="flex animate-marquee whitespace-nowrap font-display text-3xl md:text-5xl uppercase">
			{Array.from({ length: 2 }).map(() => (
				<div class="flex items-center gap-8 mr-8">
					<span>Acrobacia</span>
					<span class="text-flame">●</span>
					<span>Trapecio</span>
					<span class="text-teal">●</span>
					<span>Malabares</span>
					<span class="text-magenta">●</span>
					<span>Clown</span>
					<span class="text-violet">●</span>
					<span>Equilibrismo</span>
					<span class="text-crimson">●</span>
					<span>Teatro Físico</span>
					<span class="text-flame">●</span>
				</div>
			))}
		</div>
	</div>

	<!-- Sobre el festival -->
	<Section
		id="sobre"
		subtitle="Sobre FIC"
		title="Tres décadas celebrando el circo"
		description="Un espacio dedicado a celebrar el arte circense en todas sus formas."
		accent="sun"
	>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<Card
				accent="sun"
				icon="✦"
				title="Tradición"
				description="Desde 2002, FIC ha sido la plataforma principal para artistas circenses de toda América Latina."
				cta={{ text: "Historia", href: "#" }}
			/>
			<Card
				accent="teal"
				icon="◐"
				title="Internacional"
				description="Artistas de más de 30 países participan en nuestro festival cada año."
				cta={{ text: "Artistas", href: "/espectaculos" }}
			/>
			<Card
				accent="flame"
				icon="✺"
				title="Innovación"
				description="Combinamos técnicas tradicionales con propuestas contemporáneas y experimentales."
				cta={{ text: "Espectáculos", href: "/espectaculos" }}
			/>
		</div>
	</Section>

	<!-- Stats / Números grandes -->
	<section class="bg-navy-deep py-20 md:py-28 brushstroke">
		<div class="max-w-7xl mx-auto px-6">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
				{[
					{ num: "9", label: "Espectáculos", color: "#F4C430" },
					{ num: "7", label: "Lugares", color: "#3DBCBC" },
					{ num: "11", label: "Días", color: "#E85A2C" },
					{ num: "30+", label: "Artistas", color: "#C589B7" },
				].map(({ num, label, color }) => (
					<div class="group">
						<div class="font-display text-7xl md:text-8xl lg:text-9xl leading-none mb-2 transition-transform group-hover:-translate-y-1" style={`color:${color}`}>
							{num}
						</div>
						<div class="text-cream/70 uppercase tracking-widest text-xs font-bold">{label}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Próximos eventos -->
	<Section
		id="eventos"
		subtitle="Qué te espera"
		title="No te pierdas nada"
		description="Espectáculos, talleres y convocatorias abiertas para artistas y compañías."
		accent="teal"
	>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<Card
				accent="magenta"
				title="Convocatorias"
				description="Abierto el llamado para compañías y artistas independientes. Participá en la 5ta edición."
				cta={{ text: "Postularse", href: "/convocatorias" }}
			/>
			<Card
				accent="teal"
				title="Programación"
				description="Más de 9 espectáculos en 7 lugares emblemáticos de Montevideo."
				cta={{ text: "Ver fechas", href: "/programacion" }}
			/>
			<Card
				accent="sun"
				title="Talleres"
				description="Aprendé de maestros circenses internacionales. Talleres para todos los niveles."
				cta={{ text: "Inscribirse", href: "/talleres" }}
			/>
		</div>
	</Section>

	<!-- Ediciones anteriores -->
	<Section
		id="ediciones"
		subtitle="Nuestro Legado"
		title="Ediciones anteriores"
		description="Más de dos décadas celebrando el arte circense en Uruguay."
		dark={true}
		accent="violet"
	>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
			<Card accent="sun" title="2022" description="4ta Edición · 15.000 asistentes" />
			<Card accent="teal" title="2019" description="3ra Edición · 12.000 asistentes" />
			<Card accent="flame" title="2016" description="2da Edición · 10.000 asistentes" />
			<Card accent="magenta" title="2002" description="1ra Edición · El comienzo" />
		</div>
	</Section>

	<!-- CTA final -->
	<section class="relative bg-sun text-navy py-20 md:py-28 overflow-hidden border-y-4 border-navy">
		<div class="absolute -bottom-10 -right-10 w-80 h-80 rounded-full overflow-hidden opacity-90">
			<div class="h-1/2 bg-flame"></div>
			<div class="h-1/2 bg-teal"></div>
		</div>
		<div class="absolute -top-10 -left-10 w-56 h-56 rounded-full overflow-hidden opacity-90">
			<div class="h-1/2 bg-magenta"></div>
			<div class="h-1/2 bg-violet"></div>
		</div>
		<div class="relative max-w-4xl mx-auto px-6 text-center">
			<h2 class="font-display text-5xl md:text-7xl lg:text-8xl leading-[0.85] uppercase tracking-tighter mb-8">
				¿Listo para<br/>el festival?
			</h2>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/programacion" class="bg-navy text-cream px-8 py-4 rounded-full font-black uppercase tracking-widest text-sm hover:bg-flame transition-colors shadow-[6px_6px_0_0_#0E1B3D] hover:translate-x-1 hover:translate-y-1 hover:shadow-[3px_3px_0_0_#0E1B3D]">
					Ver programación →
				</a>
				<a href="/contacto" class="border-4 border-navy px-8 py-4 rounded-full font-black uppercase tracking-widest text-sm hover:bg-navy hover:text-cream transition-colors">
					Contactanos
				</a>
			</div>
		</div>
	</section>

	<HalfCircleStrip rows={1} cols={20} />
</Layout>
