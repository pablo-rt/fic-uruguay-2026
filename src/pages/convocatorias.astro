---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
---

<Layout title="Convocatorias | FIC Uruguay 2026">
	<!-- Hero Section -->
	<Hero 
		title="Convocatorias"
		subtitle="Participa en FIC 2026"
		description="¿Eres artista o compañía de circo? ¡Queremos verte en el escenario! Abre el llamado para la 5ta edición del Festival Internacional de Circo."
		backgroundImage="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&q=80"
	/>

	<!-- Preguntas Frecuentes -->
	<Section 
		id="faq"
		title="Preguntas Frecuentes"
		subtitle="FAQ"
		description="Respuestas a las preguntas más comunes"
	>
		<div class="max-w-3xl mx-auto space-y-6">
			<details class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-lg group cursor-pointer">
				<summary class="flex justify-between items-center font-bold text-lg">
					¿Cuál es la duración máxima del acto?
					<span class="text-[#8B3A3A] group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<p class="text-zinc-400 mt-4">La duración máxima es de 30 minutos. Los actos más cortos también son bienvenidos.</p>
			</details>

			<details class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-lg group cursor-pointer">
				<summary class="flex justify-between items-center font-bold text-lg">
					¿Hay costo de inscripción?
					<span class="text-[#8B3A3A] group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<p class="text-zinc-400 mt-4">No, la inscripción es completamente gratuita. Solo necesitas completar el formulario en línea.</p>
			</details>

			<details class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-lg group cursor-pointer">
				<summary class="flex justify-between items-center font-bold text-lg">
					¿Qué formato debe tener el video?
					<span class="text-[#8B3A3A] group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<p class="text-zinc-400 mt-4">Aceptamos MP4, MOV, AVI y WebM. El video debe tener una duración mínima de 3 minutos y máxima de 10 minutos.</p>
			</details>

			<details class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-lg group cursor-pointer">
				<summary class="flex justify-between items-center font-bold text-lg">
					¿Puedo participar si soy internacional?
					<span class="text-[#8B3A3A] group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<p class="text-zinc-400 mt-4">¡Por supuesto! Aceptamos artistas de todo el mundo. Ofrecemos apoyo con visas y alojamiento.</p>
			</details>

			<details class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-lg group cursor-pointer">
				<summary class="flex justify-between items-center font-bold text-lg">
					¿Hay apoyo económico para artistas?
					<span class="text-[#8B3A3A] group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<p class="text-zinc-400 mt-4">Sí, ofrecemos becas parciales para artistas de países en desarrollo. Consulta los términos en el formulario.</p>
			</details>
		</div>
	</Section>

	<!-- CTA -->
	<Section 
		id="cta"
		title="¿Listo para Postularte?"
		subtitle="Únete a FIC 2026"
		dark={true}
	>
		<div class="flex flex-col sm:flex-row gap-6 justify-center">
			<a 
				href="#"
				class="px-8 py-4 bg-[#8B3A3A] text-white font-bold uppercase tracking-widest rounded-lg hover:bg-[#6B2A2A] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(139,58,58,0.5)] text-center"
			>
				Enviar Solicitud
			</a>
			<a 
				href="/contacto"
				class="px-8 py-4 border-2 border-[#8B3A3A] text-[#8B3A3A] font-bold uppercase tracking-widest rounded-lg hover:bg-[#8B3A3A] hover:text-white transition-all duration-300 text-center"
			>
				Más Información
			</a>
		</div>
	</Section>
</Layout>
