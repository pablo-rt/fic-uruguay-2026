---
// src/components/Section.astro
interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    id?: string;
    dark?: boolean;
}

const { 
    title, 
    subtitle,
    description,
    id,
    dark = false
} = Astro.props;
---

<section id={id} class={`py-20 ${dark ? 'bg-zinc-950' : 'bg-[#0A0A0A]'}`}>
    <div class="max-w-7xl mx-auto px-6">
        <!-- Header -->
        <div class="mb-16 text-center">
            {subtitle && (
                <p class="text-sm md:text-base tracking-[0.3em] uppercase opacity-70 mb-4 font-light text-[#E63946]">
                    {subtitle}
                </p>
            )}
            
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase leading-tight mb-6">
                {title}
            </h2>

            {description && (
                <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto">
                    {description}
                </p>
            )}
        </div>

        <!-- Content -->
        <slot />
    </div>
</section>
