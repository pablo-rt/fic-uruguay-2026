---
interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    id?: string;
    dark?: boolean;
    accent?: 'sun' | 'teal' | 'flame' | 'magenta' | 'violet';
}

const {
    title,
    subtitle,
    description,
    id,
    dark = false,
    accent = 'sun',
} = Astro.props;

const accentMap = {
    sun: '#F4C430',
    teal: '#3DBCBC',
    flame: '#E85A2C',
    magenta: '#C589B7',
    violet: '#8E5BA8',
};
const accentHex = accentMap[accent];
const bgClass = dark ? 'bg-navy-deep' : 'bg-navy';
---

<section id={id} class={`relative ${bgClass} brushstroke py-20 md:py-28 overflow-hidden`}>

    <!-- Acento visual: círculo bicolor decorativo en una esquina -->
    <div class="absolute top-12 right-8 md:right-16 w-16 h-16 md:w-24 md:h-24 rounded-full overflow-hidden opacity-80 pointer-events-none">
        <div class="h-1/2 w-full" style={`background:${accentHex}`}></div>
        <div class="h-1/2 w-full bg-magenta"></div>
    </div>
    <div class="absolute bottom-16 left-8 w-12 h-12 md:w-16 md:h-16 rounded-full overflow-hidden opacity-70 pointer-events-none">
        <div class="h-1/2 w-full bg-teal"></div>
        <div class="h-1/2 w-full bg-flame"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6">
        <!-- Header -->
        <div class="mb-14 md:mb-20">
            {subtitle && (
                <p class="inline-block text-xs md:text-sm tracking-[0.35em] uppercase mb-4 font-bold px-3 py-1 border-2" style={`color:${accentHex}; border-color:${accentHex}`}>
                    {subtitle}
                </p>
            )}

            <h2 class="font-display text-5xl md:text-6xl lg:text-7xl leading-[0.9] text-cream uppercase tracking-tighter mb-6 max-w-4xl">
                {title}
            </h2>

            {description && (
                <p class="text-base md:text-lg text-cream/70 max-w-2xl leading-relaxed">
                    {description}
                </p>
            )}

            <div class="mt-6 flex gap-1.5">
                <span class="w-12 h-1.5" style={`background:${accentHex}`}></span>
                <span class="w-6 h-1.5 bg-teal"></span>
                <span class="w-3 h-1.5 bg-flame"></span>
            </div>
        </div>

        <slot />
    </div>
</section>
