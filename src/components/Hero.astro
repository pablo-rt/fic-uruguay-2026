---
// src/components/Hero.astro
interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    cta?: {
        text: string;
        href: string;
    };
    backgroundImage?: string;
    backgroundGradient?: boolean;
}

const { 
    title, 
    subtitle, 
    description, 
    cta,
    backgroundImage = "https://images.unsplash.com/photo-1502635385003-ee1e6a1a742d?auto=format&fit=crop&q=80",
    backgroundGradient = true
} = Astro.props;
---

<section class="relative min-h-[500px] md:min-h-[600px] lg:min-h-[700px] flex items-center justify-center overflow-hidden py-12 md:py-16">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
        {backgroundGradient && (
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A] z-10"></div>
        )}
        <img 
            src={backgroundImage}
            class="w-full h-full object-cover opacity-30 scale-105"
            alt="Hero background"
        />
    </div>

    <!-- Content -->
    <div class="relative z-20 text-center px-4 max-w-4xl">
        {subtitle && (
            <p class="text-xs md:text-sm tracking-[0.3em] uppercase opacity-70 mb-3 md:mb-4 font-light text-[#E63946]">
                {subtitle}
            </p>
        )}
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase leading-[1.1] tracking-tighter mb-4 md:mb-6">
            {title}
        </h1>
        
        {description && (
            <p class="text-base md:text-lg tracking-wide opacity-80 mb-6 md:mb-8 font-light">
                {description}
            </p>
        )}

        {cta && (
            <a 
                href={cta.href}
                class="inline-block bg-[#8B3A3A] text-white px-6 md:px-8 py-2.5 md:py-3 rounded-lg font-bold uppercase tracking-widest text-xs md:text-sm hover:bg-[#D4A574] hover:text-[#4A7C8C] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(139,58,58,0.5)]"
            >
                {cta.text}
            </a>
        )}
    </div>
</section>
