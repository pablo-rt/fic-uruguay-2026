---
// src/components/Hero.astro
interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    cta?: {
        text: string;
        href: string;
    };
    backgroundImage?: string;
    backgroundGradient?: boolean;
}

const { 
    title, 
    subtitle, 
    description, 
    cta,
    backgroundImage = "https://images.unsplash.com/photo-1502635385003-ee1e6a1a742d?auto=format&fit=crop&q=80",
    backgroundGradient = true
} = Astro.props;
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
        {backgroundGradient && (
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A] z-10"></div>
        )}
        <img 
            src={backgroundImage}
            class="w-full h-full object-cover opacity-30 scale-105"
            alt="Hero background"
        />
    </div>

    <!-- Content -->
    <div class="relative z-20 text-center px-4 max-w-4xl">
        {subtitle && (
            <p class="text-sm md:text-base tracking-[0.3em] uppercase opacity-70 mb-4 font-light text-[#E63946]">
                {subtitle}
            </p>
        )}
        
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black uppercase leading-[0.9] tracking-tighter mb-6">
            {title}
        </h1>
        
        {description && (
            <p class="text-lg md:text-xl tracking-wide opacity-80 mb-8 font-light">
                {description}
            </p>
        )}

        {cta && (
            <a 
                href={cta.href}
                class="inline-block bg-[#E63946] text-white px-8 py-3 rounded-lg font-bold uppercase tracking-widest hover:bg-[#d62828] transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(230,57,70,0.5)]"
            >
                {cta.text}
            </a>
        )}
    </div>
</section>
