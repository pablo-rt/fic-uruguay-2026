---
interface Props {
    class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
    class={className}
    viewBox="0 0 200 200"
    xmlns="http://www.w3.org/2000/svg"
    fill="currentColor"
    aria-hidden="true"
>
    <g transform="translate(100 100)">
        <!-- cuerpo arqueado del acróbata -->
        <path d="M -55 0 C -45 -38, -10 -50, 15 -45 C 35 -42, 48 -28, 50 -18 L 48 -10 C 30 -16, 10 -12, -8 -2 C -25 8, -38 18, -50 14 Z" />
        <!-- cabeza -->
        <circle cx="-50" cy="-2" r="9" />
        <!-- brazo extendido -->
        <path d="M 40 -22 L 60 -32 L 65 -28 L 45 -16 Z" />
        <!-- pierna sobre la barra -->
        <path d="M -40 8 L -32 28 L -20 32 L -22 22 Z" />
    </g>
</svg>
