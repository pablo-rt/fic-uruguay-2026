---
import HalfCircleStrip from './HalfCircleStrip.astro';
---

<footer class="relative bg-navy-deep text-cream mt-20">
    <!-- Strip de semicírculos como divisor -->
    <HalfCircleStrip rows={1} cols={20} />

    <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 mb-12">

            <!-- Logo + descripción -->
            <div class="md:col-span-4">
                <div class="flex items-baseline gap-1 mb-4">
                    <span class="font-display text-5xl text-cream leading-none">fic</span>
                    <span class="relative inline-block w-4 h-4 rounded-full overflow-hidden">
                        <span class="absolute top-0 left-0 w-full h-1/2 bg-sun"></span>
                        <span class="absolute bottom-0 left-0 w-full h-1/2 bg-teal"></span>
                    </span>
                    <span class="font-display text-lg text-sun">2026</span>
                </div>
                <p class="text-cream/70 text-sm leading-relaxed mb-6 max-w-sm">
                    Festival Internacional de Circo. Celebrando el arte circense en Uruguay desde 2002.
                </p>
                <p class="text-xs uppercase tracking-widest text-sun font-bold">17 — 27 setiembre · Montevideo</p>
            </div>

            <!-- Navegación -->
            <div class="md:col-span-2">
                <h4 class="text-xs font-black uppercase tracking-widest mb-5 text-sun">Festival</h4>
                <ul class="space-y-3 text-sm">
                    <li><a href="/" class="text-cream/70 hover:text-cream link-underline">Inicio</a></li>
                    <li><a href="/programacion" class="text-cream/70 hover:text-cream link-underline">Programación</a></li>
                    <li><a href="/espectaculos" class="text-cream/70 hover:text-cream link-underline">Espectáculos</a></li>
                    <li><a href="/talleres" class="text-cream/70 hover:text-cream link-underline">Talleres</a></li>
                </ul>
            </div>

            <div class="md:col-span-2">
                <h4 class="text-xs font-black uppercase tracking-widest mb-5 text-teal">Más</h4>
                <ul class="space-y-3 text-sm">
                    <li><a href="/convocatorias" class="text-cream/70 hover:text-cream link-underline">Convocatorias</a></li>
                    <li><a href="/contacto" class="text-cream/70 hover:text-cream link-underline">Contacto</a></li>
                    <li><a href="#" class="text-cream/70 hover:text-cream link-underline">Prensa</a></li>
                    <li><a href="#" class="text-cream/70 hover:text-cream link-underline">Privacidad</a></li>
                </ul>
            </div>

            <!-- Redes -->
            <div class="md:col-span-4">
                <h4 class="text-xs font-black uppercase tracking-widest mb-5 text-flame">Síguenos</h4>
                <div class="flex gap-3 mb-6">
                    {[
                        { label: 'IG', color: '#E85A2C' },
                        { label: 'FB', color: '#3DBCBC' },
                        { label: 'YT', color: '#B83A3A' },
                        { label: 'X', color: '#F4C430' },
                    ].map(({ label, color }) => (
                        <a href="#" class="w-12 h-12 rounded-full bg-cream text-navy font-black flex items-center justify-center hover:scale-110 transition-transform" style={`color:#0E1B3D`} aria-label={label}>
                            <span class="text-sm" style={`color:${color}`}>{label}</span>
                        </a>
                    ))}
                </div>
                <p class="text-xs text-cream/50">
                    Suscribite y enterate antes que nadie.
                </p>
                <form class="mt-3 flex gap-0">
                    <input type="email" placeholder="tu@email.com" class="flex-1 px-4 py-2.5 bg-navy/50 border-2 border-cream/20 focus:border-sun text-cream text-sm rounded-l-full outline-none transition-colors" />
                    <button class="bg-sun text-navy px-5 py-2.5 rounded-r-full text-xs font-black uppercase tracking-widest hover:bg-flame hover:text-cream transition-colors">OK</button>
                </form>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t-2 border-cream/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-cream/50 text-xs">
                &copy; 2026 Festival Internacional de Circo · Todos los derechos reservados
            </p>
            <div class="flex gap-1">
                {['#F4C430','#3DBCBC','#E85A2C','#C589B7','#8E5BA8','#B83A3A'].map(c => (
                    <span class="w-6 h-2 rounded-full" style={`background:${c}`}></span>
                ))}
            </div>
        </div>
    </div>
</footer>
