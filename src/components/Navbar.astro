---
// src/components/Navbar.astro
---

<nav class="fixed top-0 left-0 w-full z-50 bg-[#4A7C8C]/95 backdrop-blur-md border-b border-[#8B3A3A]">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="text-2xl font-black tracking-tighter hover:text-[#D4A574] transition-colors duration-300">
            FIC<span class="text-[#8B3A3A]">.</span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex gap-12 text-sm uppercase tracking-[0.15em] font-semibold">
            <a href="/convocatorias" class="text-zinc-300 hover:text-[#D4A574] transition-colors duration-300 relative group">
                Convocatorias
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#D4A574] group-hover:w-full transition-all duration-300"></span>
            </a>
            <a href="/espectaculos" class="text-zinc-300 hover:text-[#D4A574] transition-colors duration-300 relative group">
                Espectáculos
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#D4A574] group-hover:w-full transition-all duration-300"></span>
            </a>
            <a href="/talleres" class="text-zinc-300 hover:text-[#D4A574] transition-colors duration-300 relative group">
                Talleres
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#D4A574] group-hover:w-full transition-all duration-300"></span>
            </a>
        </div>

        <!-- CTA Button -->
        <a href="/contacto" class="bg-[#8B3A3A] text-white px-6 py-2.5 rounded-lg text-xs font-black uppercase tracking-widest hover:bg-[#D4A574] hover:text-[#4A7C8C] transition-all duration-300 shadow-lg hover:shadow-[0_0_20px_rgba(139,58,58,0.4)]">
            Contacto
        </a>
    </div>
</nav>

<!-- Spacer para que el contenido no se superponga con el navbar fijo -->
<div class="h-16"></div>
