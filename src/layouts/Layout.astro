---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="FIC Uruguay 2026 - Festival Internacional de Circo" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-navy text-cream font-sans antialiased min-h-screen overflow-x-hidden">

		<!-- Page loader -->
		<div id="page-loader" class="page-loader">
			<div class="page-loader-ring"></div>
		</div>

		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />

		<script is:inline>
			window.addEventListener('load', () => {
				const loader = document.getElementById('page-loader');
				if (loader) {
					setTimeout(() => loader.classList.add('loaded'), 350);
				}
			});
		</script>
	</body>
</html>

<style is:global>
	html {
		font-family: 'Inter', system-ui, sans-serif;
	}
	h1, h2, h3, h4 {
		font-family: 'Archivo Black', Impact, sans-serif;
		letter-spacing: -0.02em;
	}
</style>
