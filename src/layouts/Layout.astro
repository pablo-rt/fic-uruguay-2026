---
// src/layouts/Layout.astro
import Navbar from '../components/Navbar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="FIC Uruguay 2026 - Festival Internacional de Circo" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Syne:wght@700;800&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#0A0A0A] text-white selection:bg-[#E63946] selection:text-white">
		<Navbar />
		<slot /> </body>
</html>

<style is:global>
	:root {
		--accent: #E63946;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}
	h1, h2, h3 {
		font-family: 'Syne', sans-serif;
		letter-spacing: -0.02em;
	}
</style>